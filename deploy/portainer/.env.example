TZ=Europe/Paris
NODE_ENV=production

# Your published images on GHCR
CORTEX_API_IMAGE=ghcr.io/ngojclee/cortex-api:2026.03.25
CORTEX_MCP_IMAGE=ghcr.io/ngojclee/cortex-mcp:2026.03.25

# External LLM gateway (or your own local service)
OPENAI_API_BASE=http://10.21.1.101:8317/v1
LLM_PROXY_URL=http://10.21.1.101:8317
OPENAI_API_KEY=replace-openai-key
CLIPROXY_MANAGEMENT_KEY=replace-management-key

# App URLs and MCP auth
DASHBOARD_URL=https://cortexhub.your-domain.com
MCP_API_KEYS=replace-mcp-api-keys

# Models
MEM9_LLM_MODEL=gpt-5.1-codex-mini
MEM9_EMBEDDING_MODEL=text-embedding-3-small
