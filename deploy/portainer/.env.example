TZ=Europe/Paris
NODE_ENV=production

# ── Public URL ──
# Your domain proxied via Cloudflare Tunnel to API_PORT
DASHBOARD_URL=https://cortexhub.lengoc.me

# ── Storage ──
STACK_DATA_ROOT=/home/Docker/cortex-hub

# ── Ports ──
API_PORT=4000

# ── Secrets ──
CLIPROXY_MANAGEMENT_KEY=replace-with-a-long-random-secret

# ── LLM Proxy ──
# Default: internal container (http://llm-proxy:8317)
# Set to external if you have your own CLI Proxy API:
# LLM_PROXY_URL=http://10.21.1.101:8317
