TZ=Europe/Paris
NODE_ENV=production

# Public dashboard URL routed by your reverse proxy to the local API port below.
DASHBOARD_URL=https://cortexhub.lengoc.me

# Host path where Cortex Hub keeps all persistent data on your server.
STACK_DATA_ROOT=/home/Docker/cortex-hub

# Keep the dashboard/API on localhost, but expose MCP so other machines can connect.
API_BIND_HOST=127.0.0.1
API_PORT=4000
MCP_BIND_HOST=0.0.0.0
MCP_PORT=8318

# Shared secret between cortex-api and llm-proxy for OAuth management.
CLIPROXY_MANAGEMENT_KEY=replace-with-a-long-random-secret
