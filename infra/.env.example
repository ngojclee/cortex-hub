# Cortex Hub — Server Environment
# Copy to .env and configure values for your deployment

# ── Timezone ────────────────────────────────
TZ=Europe/Paris

# ── Runtime ────────────────────────────────
NODE_ENV=production

# ── Stack Paths ────────────────────────────
STACK_DATA_ROOT=/home/Docker/cortex-hub
API_PORT=4000

# ── Dashboard API ──────────────────────────
DASHBOARD_URL=https://cortexhub.lengoc.me

# ── CLIProxy (LLM Gateway) ──────────────────
CLIPROXY_MANAGEMENT_KEY=your-cliproxy-password-here

# ── Dashboard Auth ──────────────────────────
AUTH_ENABLED=true
AUTH_SESSION_TTL_HOURS=168
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# ── LLM Proxy URL (internal) ───────────────
LLM_PROXY_URL=http://llm-proxy:8317
