# Cortex Hub — Server Environment
# Copy to .env and fill in actual values

# ── OpenAI (for mem0 embeddings) ─────────────
OPENAI_API_KEY=sk-xxx

# ── Dashboard API ────────────────────────────
PORT=4000
NODE_ENV=production
DATABASE_PATH=/app/data/cortex.db
DASHBOARD_URL=http://localhost:4000

# ── Dashboard Auth ───────────────────────────
AUTH_ENABLED=false
AUTH_SESSION_TTL_HOURS=168
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
